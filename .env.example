# 企业微信群机器人 Webhook 完整地址（在企业微信群里添加机器人后复制）
WECHAT_WORK_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxxxxxxx

# 可选：日报 JSON 路径（默认 ./data/nanjing-daily.json）
# DAILY_REPORT_PATH=/path/to/report.json

# 可选：直接传入整段 JSON（优先级高于文件；适合 CI 上一步生成后注入）
# DAILY_REPORT_JSON={"date":"2026-05-11","secondHand":[],"newHouse":[]}
